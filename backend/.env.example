# Copy to .env for local development:
#   cp .env.example .env
#
# Generate a new signing key:
#   openssl rand -hex 32

# Required in production (Render → Environment, or backend/.env locally).
INVITE_SIGNING_KEY=

# Comma-separated frontend origins (omit or * for local dev)
ALLOWED_ORIGINS=http://localhost:5173,https://closr-live.vercel.app

# Optional
PORT=3000
ROOM_MAX_PARTICIPANTS=12
ROOM_MAX_LIFETIME_MS=14400000
ROOM_EMPTY_TTL_MS=300000
